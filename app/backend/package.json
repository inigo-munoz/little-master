{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "bundle": "bash ../../scripts/bundle-backend.sh",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "phb:import": "npx tsx src/db/phb-import-cli.ts",
    "phb:import:force": "npx tsx src/db/phb-import-cli.ts --force",
    "test": "vitest run"
  },
  "dependencies": {
    "@dnd/domain": "workspace:*",
    "@dnd/shared": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.0",
    "@prisma/client": "^5.13.0",
    "@types/pdf-parse": "^1.1.5",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pino": "^9.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.28.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.13.0",
    "supertest": "^7.2.2",
    "tsx": "^4.8.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
