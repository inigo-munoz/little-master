{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "test": "vitest run"
  },
  "dependencies": {
    "@dnd/domain": "workspace:*",
    "@dnd/shared": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/sensible": "^5.5.0",
    "@prisma/client": "^5.13.0",
    "@types/pdf-parse": "^1.1.5",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^7.2.0",
    "prisma": "^5.13.0",
    "supertest": "^7.2.2",
    "tsx": "^4.8.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  }
