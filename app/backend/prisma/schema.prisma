// This is the Prisma schema for the D&D Campaign Assistant.
// SQLite for MVP. To migrate to PostgreSQL later, only the provider changes
// and you add pgvector for embeddings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns Campaign[]
}

// ─── Campaigns ────────────────────────────────────────────────────────────────
model Campaign {
  id          String   @id @default(cuid())
  title       String
  description String?
  system      String   @default("D&D 2024")
  status      String   @default("active") // CampaignStatus enum
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  sessions        Session[]
  npcs            Npc[]
  locations       Location[]
  factions        Faction[]
  documents       Document[]
  campaignRules   CampaignRule[]
  changeLogs      ChangeLog[]
  issues          Issue[]
  assistantRuns   AssistantRun[]
  players         Player[]
  encounters      Encounter[]
  entityRelations EntityRelation[]
}

// ─── Sessions ─────────────────────────────────────────────────────────────────
model Session {
  id            String    @id @default(cuid())
  campaignId    String
  title         String
  summary       String?
  notes         String?
  sessionNumber Int
  playedAt      DateTime?
  sourceType    String    @default("campaign") // official | srd | campaign | homebrew_* | ai_inferred
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ─── NPCs ─────────────────────────────────────────────────────────────────────
model Npc {
  id          String   @id @default(cuid())
  campaignId  String
  name        String
  role        String?
  description String?
  rawContent  String?  // Original Obsidian note for export fidelity
  status      String   @default("alive") // NpcStatus enum
  disposition String   @default("neutral") // NpcDisposition: ally | neutral | enemy
  sourceType  String   @default("campaign") // official | srd | campaign | homebrew_* | ai_inferred
  tags        String   @default("[]") // JSON array stored as string in SQLite
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Stat block de combate
  armorClass      Int?
  hitPoints       String?   // ej: "45 (7d8 + 14)"
  speed           String?   // ej: "30 pies"
  strength        Int?
  dexterity       Int?
  constitution    Int?
  intelligence    Int?
  wisdom          Int?
  charisma        Int?
  savingThrows    String?   // ej: "DES +4, CAR +3"
  skills          String?
  resistances     String?
  immunities      String?
  senses          String?
  languages       String?
  challengeRating String?   // ej: "3 (700 XP)"
  traits          String?   // JSON: [{name, description}]
  actions         String?   // JSON: [{name, description}]
  bonusActions    String?   // JSON: [{name, description}]
  reactions       String?   // JSON: [{name, description}]
  npcType         String?   // "monster" | "player"
  npcClass        String?
  npcLevel        Int?
  npcSpecies      String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ─── Locations ────────────────────────────────────────────────────────────────
model Location {
  id               String     @id @default(cuid())
  campaignId       String
  name             String
  description      String?
  parentLocationId String?
  sourceType       String     @default("campaign") // official | srd | campaign | homebrew_* | ai_inferred
  tags             String     @default("[]")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  campaign       Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  parentLocation Location? @relation("LocationHierarchy", fields: [parentLocationId], references: [id], onDelete: SetNull)
  subLocations   Location[] @relation("LocationHierarchy")
}

// ─── Factions ─────────────────────────────────────────────────────────────────
model Faction {
  id          String   @id @default(cuid())
  campaignId  String
  name        String
  description String?
  alignment   String?
  disposition String   @default("unknown")
  sourceType  String   @default("campaign") // official | srd | campaign | homebrew_* | ai_inferred
  tags        String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ─── Entity Relations ─────────────────────────────────────────────────────────
model EntityRelation {
  id           String   @id @default(cuid())
  campaignId   String
  fromType     String   // "npc" | "faction" | "location"
  fromId       String
  toType       String   // "npc" | "faction" | "location"
  toId         String
  relationType String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([fromType, fromId])
  @@index([toType, toId])
}

// ─── Documents ────────────────────────────────────────────────────────────────
model Document {
  id             String   @id @default(cuid())
  campaignId     String?
  title          String
  path           String   // relative to /data/documents/
  contentType    String   // markdown | plaintext | pdf
  sourceType     String   // official | srd | campaign | homebrew_* | ai_inferred
  authorityLevel String   // high | medium | low
  version        String   @default("1.0")
  isIndexed      Boolean  @default(false)
  chunkCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  chunks   DocumentChunk[]
}

// ─── Document Chunks (for semantic search) ───────────────────────────────────
model DocumentChunk {
  id             String   @id @default(cuid())
  documentId     String
  campaignId     String?
  content        String
  chunkIndex     Int
  sourceType     String
  authorityLevel String
  // Embedding stored as JSON array string (SQLite MVP)
  // In PostgreSQL + pgvector, this becomes a vector column
  embeddingJson  String?
  createdAt      DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// ─── Rule Sources ─────────────────────────────────────────────────────────────
model RuleSource {
  id             String  @id @default(cuid())
  name           String
  sourceType     String
  authorityLevel String
  version        String?
  description    String?

  campaignRules CampaignRule[]
}

// ─── Campaign Rules ───────────────────────────────────────────────────────────
model CampaignRule {
  id             String   @id @default(cuid())
  campaignId     String
  title          String
  content        String
  sourceId       String?
  sourceType     String
  authorityLevel String
  version        String   @default("1.0")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ruleSource RuleSource? @relation(fields: [sourceId], references: [id])
}

// ─── Change Log ───────────────────────────────────────────────────────────────
model ChangeLog {
  id         String   @id @default(cuid())
  campaignId String?
  entityType String
  entityId   String
  beforeJson String?
  afterJson  String?
  reason     String?
  source     String?
  authorType String   // user | ai | system
  createdAt  DateTime @default(now())

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([entityType, entityId])
}

// ─── Issues ───────────────────────────────────────────────────────────────────
model Issue {
  id                String    @id @default(cuid())
  campaignId        String?
  type              String
  severity          String
  status            String    @default("open")
  description       String
  relatedEntityType String?
  relatedEntityId   String?
  resolution        String?
  createdAt         DateTime  @default(now())
  resolvedAt        DateTime?

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([campaignId, status])
}

// ─── LLM Configs ──────────────────────────────────────────────────────────────
model LlmConfig {
  id                  String    @id @default(cuid())
  provider            String    // openai | anthropic | openrouter | ollama
  model               String
  authMethod          String    @default("apikey") // apikey | oauth
  apiKeyEncrypted     String?   // NEVER returned to frontend plain
  isActive            Boolean   @default(false)
  keyIsValid          Boolean?
  keyValidatedAt      DateTime?
  oauthAccessToken    String?   // encrypted
  oauthRefreshToken   String?   // encrypted
  oauthExpiresAt      DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  assistantRuns AssistantRun[]
}

// ─── Assistant Runs ───────────────────────────────────────────────────────────
model AssistantRun {
  id            String   @id @default(cuid())
  campaignId    String?
  mode          String   // archivista | designer | rule_reviewer | auditor | session_director
  prompt        String
  response      String?
  contextChunks String   @default("[]") // JSON array of chunk IDs
  toolsUsed     String   @default("[]") // JSON array of MCP tool names
  tokensUsed    Int?
  llmConfigId   String?
  createdAt     DateTime @default(now())

  campaign  Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  llmConfig LlmConfig? @relation(fields: [llmConfigId], references: [id])
}

// ─── App Settings ─────────────────────────────────────────────────────────────
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Players (PJs) ────────────────────────────────────────────────────────────
model Player {
  id          String   @id @default(cuid())
  campaignId  String
  name        String
  playerName  String?
  class       String?
  subclass    String?
  race        String?
  background       String?
  backgroundLocked Boolean @default(false)
  alignment        String?
  level       Int      @default(1)
  experiencePoints Int @default(0)

  // Combat stats
  hp          Int?
  hpMax       Int?
  hpTemp      Int?
  ac          Int?
  initiative  Int?
  speed       Int?
  size        String?  // Tiny, Small, Medium, Large, Huge, Gargantuan
  shield      Boolean  @default(false)
  hitDice     String?  // e.g. "6d8"
  hitDiceSpent        Int @default(0)
  deathSaveSuccesses  Int @default(0)
  deathSaveFailures   Int @default(0)
  exhaustionLevel     Int @default(0)  // 0-6, D&D 2024

  // Ability scores
  strength     Int?
  dexterity    Int?
  constitution Int?
  intelligence Int?
  wisdom       Int?
  charisma     Int?

  // Saving throw proficiencies (JSON array of ability names)
  savingThrows String @default("[]")

  // Skill proficiencies (JSON array of skill names)
  skillProficiencies String @default("[]")
  skillExpertise     String @default("[]")

  // Other proficiencies
  armorProficiencies  String?
  armorTraining       String?  // "Light, Medium, Heavy, Shields"
  weaponProficiencies String?
  toolProficiencies   String?
  languages           String?
  proficiencyBonus    Int?     // computed by level, stored for reference

  // Spellcasting (D&D 2024: todos los hechizos son preparados)
  spellcastingAbility String?
  spellSaveDC         Int?
  spellAttackBonus    Int?
  spellSlots          String @default("{}") // JSON: {"1":{"max":4,"used":0},...,"pact":{"max":2,"used":0}}
  spellsPrepared      String @default("[]") // legacy — usar spells
  cantrips            String @default("[]") // legacy — usar spells con level 0
  spells              String @default("[]") // JSON: [{id,name,level,concentration,ritual}]

  // Equipment & inventory
  inventory    String @default("[]") // JSON array
  weapons      String @default("[]") // JSON [{name, atkBonus, damageDie, damageType, notes}]
  magicItems   String @default("[]") // JSON [{name, description, attuned}] — max 3 attuned
  currency     String @default("{}") // JSON: {cp,sp,ep,gp,pp}

  // Clase y multiclase (D&D 2024)
  classes       String  @default("[]")  // JSON: [{class, level, subclass}]
  hpRolls       String  @default("[]")  // JSON: [{level, value, rolled}]
  equippedArmor String?                 // clave de ARMOR_LIST, ej: "scaleMail"
  hpUseAverage  Boolean @default(true)  // true=media, false=dado manual

  // Features, traits & dons
  features      String @default("[]") // JSON array of {name, description, source}
  speciesTraits String @default("[]") // JSON — rasgos de especie (D&D 2024)
  feats         String @default("[]") // JSON — dones (backgrounds dan 1 feat a nivel 1)
  traits        String?  // personality traits
  ideals        String?
  bonds         String?
  flaws         String?
  backstory     String?

  // Appearance
  age          String?
  height       String?
  weight       String?
  eyes         String?
  skin         String?
  hair         String?
  appearance   String?

  // Passive stats (computed but stored for reference)
  passivePerception Int?

  // Inspiración (D&D 2024: Heroic Inspiration)
  inspiration       Boolean @default(false)  // legacy
  heroicInspiration Boolean @default(false)  // D&D 2024

  status      String   @default("active")
  notes       String?
  tags        String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ─── Encounters ───────────────────────────────────────────────────────────────
model Encounter {
  id          String   @id @default(cuid())
  campaignId  String
  title       String?
  monsters    String   @default("[]") // JSON: [{name, cr, count}, ...]
  partySize   Int
  partyLevel  Int
  baseXp      Int
  adjustedXp  Int
  difficulty  String   // trivial | easy | medium | hard | deadly | impossible
  notes       String?
  createdAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

